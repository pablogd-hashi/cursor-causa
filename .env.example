# Causa environment — copy to .env and fill in. NEVER commit the real .env.
#
# Every variable below is documented with: what uses it, how to obtain it, and
# the least-privilege scope it should be granted. Causa is read-only against all
# external systems; nothing here grants write access.

# --- Cursor Agent SDK (the Cloud Agent investigator) -------------------------
# Used by: sdk-runner (Node) / CursorInvestigator.
# Get it: cursor.com -> Dashboard -> Integrations -> API Keys. Requires Pro.
# Scope: cloud-agent runs only. The Cloud Agent runs with autoCreatePR=false.
CURSOR_API_KEY=

# The repository the Cloud Agent clones and investigates (one repo per run).
CURSOR_TARGET_REPO=https://github.com/pablogd-hashi/cursor-causa
CURSOR_TARGET_REF=main
# Cursor model id for the cloud run (e.g. composer-2). Configurable.
CURSOR_MODEL=composer-2
# NOTE: the Cloud Agent's clone uses the *Cursor GitHub app*, authorised on the
# single repo above. That is a separate grant from GITHUB_PERSONAL_ACCESS_TOKEN.

# --- GitHub MCP (triage: candidate commits/PRs in the incident window) -------
# Used by: github-mcp-server (spawned read-only by Causa's MCP client).
# Get it: GitHub -> Settings -> Developer settings -> Fine-grained tokens.
# Scope: repository = pablogd-hashi/cursor-causa ONLY; read-only Contents +
#        Pull requests + Commits. The MCP server also runs with --read-only.
GITHUB_PERSONAL_ACCESS_TOKEN=

# --- Grafana MCP (triage: metric signature + incident window + deeplinks) ----
# Used by: mcp-grafana (spawned with --disable-write by Causa's MCP client).
GRAFANA_URL=http://localhost:3000
# Get it: Grafana -> Administration -> Service accounts -> Add service account
#         token. Role: Viewer. (GRAFANA_API_KEY is deprecated; use this.)
GRAFANA_SERVICE_ACCOUNT_TOKEN=

# --- Inbound alert webhook (Alertmanager -> Causa) ---------------------------
# Used by: causa-api to verify the alert webhook is genuine.
# Get it: self-generated random secret; configure the same value in Alertmanager.
CAUSA_WEBHOOK_SECRET=

# --- Light narration LLM (optional; narration only, never decides the RCA) ----
# Used by: causa/llm.py. MODEL_PROVIDER = openai | ollama | mock.
MODEL_PROVIDER=mock
LLM_API_KEY=
# For the air-gapped story: point at a local Ollama instead.
# OLLAMA_BASE_URL=http://localhost:11434
