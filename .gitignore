.env
.env.*
!.env.example

# --- Python ------------------------------------------------------------------
.venv/
venv/
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

